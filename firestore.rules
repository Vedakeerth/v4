rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Admin check helper
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "vaelinsa@gmail.com";
    }

    // Products: Public read, Admin write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders: Admin only (Public reads go through our secure API)
    match /orders/{orderId} {
      allow read, write: if isAdmin();
    }

    // Pages content: Public read, Admin write
    match /pages/{pageId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}